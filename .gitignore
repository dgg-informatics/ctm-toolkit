.venv/
__pycache__/
*.pyc
*.egg-info/
dist/
.pytest_cache/
.env

# data/real/ — real patient data, never commit (HIPAA)
data/real/*
!data/real/.gitkeep

# data/dump/ — scratch/misc files, not tracked
data/dump/*
!data/dump/.gitkeep

# data/raw/ and data/normalized/ are committed (example/reference files)
